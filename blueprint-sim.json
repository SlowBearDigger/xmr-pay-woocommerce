{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "login": true,
  "siteOptions": {
    "blogname": "xmr-pay Test Store",
    "woocommerce_currency": "USD",
    "woocommerce_default_country": "US:CA",
    "woocommerce_calc_taxes": "no"
  },
  "plugins": ["woocommerce"],
  "steps": [
    {
      "step": "activatePlugin",
      "pluginPath": "xmr-pay-for-woocommerce/xmr-pay-for-woocommerce.php"
    },
    {
      "step": "runPHP",
      "code": "<?php require_once('/wordpress/wp-load.php'); update_option('woocommerce_xmrpay_settings', array('enabled'=>'yes','title'=>'Monero (XMR)','description'=>'Pay privately with Monero.','agent_url'=>'http://127.0.0.1:8788','agent_token'=>'','webhook_secret'=>'whsec_test_xmrpay','min_confirmations'=>'1','test_amount'=>'0.01')); echo 'CONFIG_OK';"
    },
    {
      "step": "runPHP",
      "code": "<?php require_once('/wordpress/wp-load.php'); $ex=wc_get_products(array('name'=>'Test Item','limit'=>1)); if($ex){$pid=$ex[0]->get_id();}else{$p=new WC_Product_Simple();$p->set_name('Test Item');$p->set_regular_price('12');$p->set_status('publish');$pid=$p->save();} $order=wc_create_order(); $order->add_product(wc_get_product($pid),1); $order->set_payment_method('xmrpay'); $order->set_address(array('first_name'=>'Test','last_name'=>'Buyer','email'=>'test@example.com','address_1'=>'1 St','city'=>'Town','postcode'=>'12345','country'=>'US','state'=>'CA'),'billing'); $order->calculate_totals(); $order->save(); $gws=WC()->payment_gateways()->payment_gateways(); $res=isset($gws['xmrpay'])?$gws['xmrpay']->process_payment($order->get_id()):array('error'=>'no gateway'); echo 'XMRPAY_RESULT '.json_encode(array('order_id'=>$order->get_id(),'result'=>$res,'address'=>$order->get_meta('_xmrpay_address'),'amount'=>$order->get_meta('_xmrpay_amount'),'order_key'=>$order->get_order_key(),'status'=>$order->get_status()));"
    }
  ]
}
